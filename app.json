{
  "expo": {
    "name": "DIY",
    "slug": "DIY",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.DIY"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.DIY"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-localization",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "DIY usa tu ubicación solo para mostrar chollos de tu país."
        }
      ]
    ],
    "extra": {
      "appVariant": "production",
      "apiUrl": "https://diy-backend.up.railway.app",
      "eas": {
        "projectId": "aa299165-5552-4ca4-bc3a-d308d0fb0dfd"
      }
    }
  }
}
